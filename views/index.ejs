<%- include('_head', {title:'首页'}) %>

<% if (locals.user) { %>
<!-- ═══════ 已登录状态 ═══════ -->
<div class="text-center py-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-2">
    你好，<%= locals.user.nickname || locals.user.phone %> 👋
  </h1>
  <p class="text-gray-500 text-sm mb-8">
    <%= locals.user.grade %> · <%= locals.user.region %> · 开始你的志愿审单吧
  </p>

  <div class="flex flex-wrap gap-4 justify-center">
    <a href="/student/new"
       class="inline-flex items-center gap-2 px-8 py-3 bg-[#c0392b] hover:bg-[#96281b] text-white font-semibold rounded-lg shadow transition text-base">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      新建审单
    </a>
    <a href="/student"
       class="inline-flex items-center gap-2 px-8 py-3 bg-white hover:bg-gray-50 text-gray-700 font-semibold rounded-lg shadow border transition text-base">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"/>
      </svg>
      我的学生
    </a>
    <a href="/report"
       class="inline-flex items-center gap-2 px-8 py-3 bg-white hover:bg-gray-50 text-gray-700 font-semibold rounded-lg shadow border transition text-base">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
      </svg>
      审单报告
    </a>
  </div>
</div>

<!-- 使用流程 -->
<div class="bg-white rounded-xl shadow p-6 mt-4">
  <h2 class="text-base font-semibold text-gray-700 mb-4">📋 使用流程</h2>
  <ol class="flex flex-col md:flex-row gap-4">
    <% const steps = [
      {n:'1', label:'新建学生档案', desc:'填写姓名、分数、位次、选科等基本信息', href:'/student/new'},
      {n:'2', label:'导入志愿表', desc:'上传 Excel 志愿表，系统自动解析', href:'/upload'},
      {n:'3', label:'查看审单报告', desc:'系统自动匹配位次、选科、身体限制', href:'/report'},
    ] %>
    <% steps.forEach((s, i) => { %>
    <li class="flex-1 flex gap-3 items-start">
      <div class="w-8 h-8 rounded-full bg-[#c0392b] text-white text-sm font-bold flex-shrink-0 flex items-center justify-center">
        <%= s.n %>
      </div>
      <div>
        <a href="<%= s.href %>" class="font-medium text-gray-800 hover:text-[#c0392b]"><%= s.label %></a>
        <p class="text-xs text-gray-500 mt-0.5"><%= s.desc %></p>
      </div>
    </li>
    <% if(i < steps.length-1) { %>
    <li class="hidden md:flex items-center text-gray-300 text-lg">→</li>
    <% } %>
    <% }) %>
  </ol>
</div>

<% } else { %>
<!-- ═══════ 未登录状态 ═══════ -->
<div class="text-center py-16">
  <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-red-50 mb-6">
    <svg class="w-10 h-10 text-[#c0392b]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
    </svg>
  </div>
  <h1 class="text-3xl font-bold text-gray-900 mb-3">重庆高考志愿审单系统</h1>
  <p class="text-gray-500 mb-8 max-w-lg mx-auto text-sm leading-relaxed">
    智能核查选科匹配 · 位次风险评估 · 体检限制提醒 · 中外合作预警<br>
    助力重庆考生科学填报志愿
  </p>

  <div class="flex flex-wrap gap-4 justify-center">
    <a href="/register"
       class="inline-flex items-center gap-2 px-8 py-3 bg-[#c0392b] hover:bg-[#96281b] text-white font-semibold rounded-lg shadow transition text-base">
      立即注册
    </a>
    <a href="/login"
       class="inline-flex items-center gap-2 px-8 py-3 bg-white hover:bg-gray-50 text-gray-700 font-semibold rounded-lg shadow border transition text-base">
      已有账号，登录
    </a>
  </div>
</div>

<!-- 功能亮点 -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-2">
  <div class="bg-white rounded-xl shadow p-6 text-center">
    <div class="w-12 h-12 rounded-full bg-red-50 flex items-center justify-center mx-auto mb-3">
      <svg class="w-6 h-6 text-[#c0392b]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
    </div>
    <h3 class="font-semibold text-gray-800 mb-1">选科匹配检查</h3>
    <p class="text-sm text-gray-500">自动核对你的选科组合是否满足院校专业要求，杜绝选科不符</p>
  </div>

  <div class="bg-white rounded-xl shadow p-6 text-center">
    <div class="w-12 h-12 rounded-full bg-orange-50 flex items-center justify-center mx-auto mb-3">
      <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
      </svg>
    </div>
    <h3 class="font-semibold text-gray-800 mb-1">位次风险评估</h3>
    <p class="text-sm text-gray-500">根据历年录取位次，智能划分冲/稳/保区间，一眼看清风险</p>
  </div>

  <div class="bg-white rounded-xl shadow p-6 text-center">
    <div class="w-12 h-12 rounded-full bg-green-50 flex items-center justify-center mx-auto mb-3">
      <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
      </svg>
    </div>
    <h3 class="font-semibold text-gray-800 mb-1">体检限制预警</h3>
    <p class="text-sm text-gray-500">自动关联体检受限代码，提示色盲/身高/视力等专业限制</p>
  </div>
</div>

<% } %>

<%- include('_foot') %>
