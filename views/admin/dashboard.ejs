<%- include('../_head', {title:'管理后台'}) %>

<div class="space-y-6">
  <!-- 管理后台导航 -->
  <div class="flex gap-3 text-sm border-b border-gray-200 pb-3">
    <a href="/admin" class="px-3 py-1.5 bg-[#c0392b] text-white rounded-lg font-medium">仪表盘</a>
    <a href="/admin/users" class="px-3 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg transition">用户管理</a>
    <a href="/admin/audits" class="px-3 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg transition">审单记录</a>
    <a href="/admin/plans" class="px-3 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg transition">志愿库管理</a>
    <a href="/admin/export" class="px-3 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg transition">导出CSV</a>
  </div>

  <!-- 统计卡片 -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <div class="bg-white rounded-xl shadow p-5">
      <div class="text-sm text-gray-500">注册用户</div>
      <div class="text-2xl font-bold text-gray-900 mt-1"><%= stats.totalUsers %></div>
      <div class="text-xs text-green-600 mt-1">今日 +<%= stats.todayUsers %></div>
    </div>
    <div class="bg-white rounded-xl shadow p-5">
      <div class="text-sm text-gray-500">审单数</div>
      <div class="text-2xl font-bold text-gray-900 mt-1"><%= stats.totalAudits %></div>
      <div class="text-xs text-green-600 mt-1">今日 +<%= stats.todayAudits %></div>
    </div>
    <div class="bg-white rounded-xl shadow p-5">
      <div class="text-sm text-gray-500">今日新注册</div>
      <div class="text-2xl font-bold text-[#c0392b] mt-1"><%= stats.todayUsers %></div>
    </div>
    <div class="bg-white rounded-xl shadow p-5">
      <div class="text-sm text-gray-500">今日审单</div>
      <div class="text-2xl font-bold text-[#c0392b] mt-1"><%= stats.todayAudits %></div>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- 注册趋势（近7天） -->
    <div class="bg-white rounded-xl shadow p-6">
      <h3 class="text-sm font-semibold text-gray-700 mb-4">📊 注册趋势（近7天）</h3>
      <% if (trend.length > 0) { %>
        <% const maxCnt = Math.max(...trend.map(t => t.cnt), 1) %>
        <div class="flex items-end gap-2 h-40">
          <% trend.forEach(t => { %>
            <div class="flex-1 flex flex-col items-center">
              <div class="text-xs text-gray-500 mb-1"><%= t.cnt %></div>
              <div class="w-full bg-[#c0392b] rounded-t transition-all" style="height: <%= Math.max(4, (t.cnt / maxCnt) * 120) %>px"></div>
              <div class="text-xs text-gray-400 mt-1"><%= t.day.slice(5) %></div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p class="text-sm text-gray-400">暂无数据</p>
      <% } %>
    </div>

    <!-- 热门学校 TOP 10 -->
    <div class="bg-white rounded-xl shadow p-6">
      <h3 class="text-sm font-semibold text-gray-700 mb-4">🏫 热门学校 TOP 10</h3>
      <% if (popularSchools.length > 0) { %>
        <div class="space-y-2">
          <% popularSchools.forEach((s, i) => { %>
            <div class="flex items-center gap-3">
              <span class="w-6 h-6 rounded-full text-xs font-bold flex items-center justify-center
                <%= i < 3 ? 'bg-[#c0392b] text-white' : 'bg-gray-100 text-gray-500' %>"><%= i + 1 %></span>
              <span class="flex-1 text-sm text-gray-700 truncate"><%= s.name %></span>
              <span class="text-sm font-medium text-gray-900"><%= s.cnt %>次</span>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p class="text-sm text-gray-400">暂无数据</p>
      <% } %>
    </div>
  </div>

  <!-- 最近注册用户 -->
  <div class="bg-white rounded-xl shadow p-6">
    <h3 class="text-sm font-semibold text-gray-700 mb-4">👤 最近注册用户</h3>
    <% if (recentUsers.length > 0) { %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 text-gray-500 text-left">
              <th class="pb-2 font-medium">手机号</th>
              <th class="pb-2 font-medium">昵称</th>
              <th class="pb-2 font-medium">年级</th>
              <th class="pb-2 font-medium">区县</th>
              <th class="pb-2 font-medium">注册时间</th>
            </tr>
          </thead>
          <tbody>
            <% recentUsers.forEach(u => { %>
            <tr class="border-b border-gray-50">
              <td class="py-2"><%= u.phone %></td>
              <td class="py-2"><%= u.nickname || '-' %></td>
              <td class="py-2"><%= u.grade %></td>
              <td class="py-2"><%= u.region %></td>
              <td class="py-2 text-gray-400"><%= u.created_at %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p class="text-sm text-gray-400">暂无注册用户</p>
    <% } %>
  </div>
</div>

<%- include('../_foot') %>
