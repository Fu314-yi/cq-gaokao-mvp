<%
// 标签中文名映射
function tagLabel(tag) {
  const map = {
    'unmatched': '缺少录取数据',
    'unmatched_school': '院校未匹配',
    'no_library_link': '未关联志愿库',
    'selection_mismatch': '选科不满足',
    'body_risk': '体检受限',
    'body_check_unavailable': '无法检查体检',
    'major_not_in_plan': '专业未匹配',
    'major_diff_from_library': '专业名与库不同',
    'no_library': '无志愿库',
    'maybe_unwanted_coop': '中外合作未确认',
  };
  return map[tag] || tag;
}
%>
<%- include('_head', {title: student.name + ' — 审单报告'}) %>

<!-- 顶部工具栏 -->
<div class="flex items-center gap-3 mb-5 print:hidden">
  <a href="/report" class="text-gray-400 hover:text-gray-600">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
  </a>
  <h1 class="text-xl font-bold text-gray-900"><%= student.name %> — 审单报告</h1>
  <div class="ml-auto flex gap-2">
    <a href="/upload?student_id=<%= student.id %>"
       class="px-4 py-1.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold rounded-lg transition">
      重新导入志愿
    </a>
    <a href="/student/<%= student.id %>"
       class="px-4 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-semibold rounded-lg transition">
      学生档案
    </a>
    <button onclick="window.print()"
            class="px-4 py-1.5 bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 text-sm font-semibold rounded-lg transition">
      🖨 打印
    </button>
  </div>
</div>

<!-- 学生概要卡片 -->
<div class="bg-white rounded-xl shadow p-5 mb-5 grid grid-cols-2 md:grid-cols-7 gap-4 text-sm">
  <div>
    <span class="text-gray-400 block text-xs mb-0.5">高考总分</span>
    <strong class="text-xl text-gray-900"><%= student.total_score %></strong>
  </div>
  <div>
    <span class="text-gray-400 block text-xs mb-0.5">投档分</span>
    <strong class="text-xl text-amber-600">
      <%= student.filing_score != null ? student.filing_score : (student.total_score + student.bonus) %>
    </strong>
  </div>
  <div>
    <span class="text-gray-400 block text-xs mb-0.5">全市位次</span>
    <strong class="text-xl text-gray-900"><%= student.rank ? student.rank.toLocaleString() : '—' %></strong>
  </div>
  <div>
    <span class="text-gray-400 block text-xs mb-0.5">首选科目</span>
    <strong><%= student.prime %></strong>
  </div>
  <div>
    <span class="text-gray-400 block text-xs mb-0.5">再选科目</span>
    <strong><%= student.elective1 %> / <%= student.elective2 %></strong>
  </div>
  <div>
    <span class="text-gray-400 block text-xs mb-0.5">民族 / 加分</span>
    <strong><%= student.nation %> / +<%= student.bonus %></strong>
  </div>
  <div>
    <span class="text-gray-400 block text-xs mb-0.5">接受收费</span>
    <% if ((student.accepted_tuition_tags || []).length > 0) { %>
    <strong class="text-sm"><%= student.accepted_tuition_tags.join('、') %></strong>
    <% } else { %>
    <strong class="text-sm text-gray-300">未选</strong>
    <% } %>
  </div>
</div>

<!-- 身体受限提示 -->
<% if(student.body_flags && student.body_flags.length) { %>
<div class="bg-amber-50 border border-amber-200 rounded-xl p-3 mb-4 flex flex-wrap gap-2 items-center">
  <span class="text-xs font-semibold text-amber-700">⚠️ 身体受限：</span>
  <% student.body_flags.forEach(f => { %>
  <span class="px-2 py-0.5 bg-amber-100 text-amber-800 text-xs rounded border border-amber-200"><%= f %></span>
  <% }) %>
</div>
<% } %>

<!-- 全局风险横幅 -->
<% if(globals && globals.length) { %>
<div class="bg-red-50 border-2 border-red-300 rounded-xl p-4 mb-5">
  <div class="flex items-center gap-2 mb-2">
    <span class="text-lg">🚨</span>
    <strong class="text-red-800">全局风险预警</strong>
  </div>
  <% globals.forEach(g => { %>
    <% if(g === 'insufficient_safety') { %>
    <p class="text-red-700 text-sm mb-1">⚠️ <strong>滑档风险：保底不足</strong> — 最后 5 条志愿全部在红色区间，没有有效保底院校，一旦冲的志愿全落空将直接滑档。</p>
    <% } else if(g === 'has_unwanted_coop') { %>
    <p class="text-amber-700 text-sm mb-1">🟡 <strong>中外合作未确认</strong> — 存在中外合作办学专业，但考生档案未勾选"接受中外合作"，请确认家庭经济承受能力。</p>
    <% } %>
  <% }) %>
</div>
<% } %>

<!-- 统计概览 -->
<% if(items.length > 0) { %>
<div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-5">
  <div class="bg-red-50 rounded-xl border-2 border-red-200 p-3 text-center">
    <div class="text-2xl font-bold text-red-600"><%= stats.red %></div>
    <div class="text-xs text-red-500 mt-0.5 font-semibold">🔴 必须改（退档级）</div>
  </div>
  <div class="bg-amber-50 rounded-xl border-2 border-amber-200 p-3 text-center">
    <div class="text-2xl font-bold text-amber-600"><%= stats.yellow %></div>
    <div class="text-xs text-amber-500 mt-0.5 font-semibold">🟡 建议改（边缘）</div>
  </div>
  <div class="bg-green-50 rounded-xl border-2 border-green-200 p-3 text-center">
    <div class="text-2xl font-bold text-green-600"><%= stats.green %></div>
    <div class="text-xs text-green-500 mt-0.5 font-semibold">🟢 安全（保底）</div>
  </div>
  <div class="bg-gray-50 rounded-xl border border-gray-200 p-3 text-center">
    <div class="text-2xl font-bold text-gray-400"><%= stats.unknown %></div>
    <div class="text-xs text-gray-400 mt-0.5">无数据</div>
  </div>
</div>
<% } %>

<!-- ═══════════════════════════════════════════════════════════════ -->
<!-- ① 红色区：必须改 -->
<!-- ═══════════════════════════════════════════════════════════════ -->
<%
const redItems = items.filter(it => it.zone === 'red');
if (redItems.length > 0) { %>
<div class="bg-white rounded-xl shadow border-l-4 border-red-500 overflow-hidden mb-5">
  <div class="px-5 py-3 bg-red-50 border-b border-red-100 flex items-center gap-2">
    <span class="text-lg">🔴</span>
    <h2 class="font-bold text-red-800">必须改 — 退档级风险</h2>
    <span class="ml-auto text-xs text-red-400 font-medium"><%= redItems.length %> 条</span>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-red-50/50 text-xs text-red-600 uppercase tracking-wide">
        <tr>
          <th class="px-3 py-2.5 text-center w-8">序</th>
          <th class="px-3 py-2.5 text-left min-w-[120px]">学校</th>
          <th class="px-3 py-2.5 text-left min-w-[100px]">专业</th>
          <th class="px-3 py-2.5 text-left">风险原因</th>
          <th class="px-3 py-2.5 text-right w-20">参考位次</th>
          <th class="px-3 py-2.5 text-right w-20">位次比</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-red-50">
        <% redItems.forEach(it => { %>
        <tr class="hover:bg-red-50/30 align-top">
          <td class="px-3 py-2.5 text-center text-gray-400 font-mono"><%= it.seq %></td>
          <td class="px-3 py-2.5">
            <div class="font-medium text-gray-900"><%= it.school_name_input || '—' %></div>
            <% if(it.lib_school && it.lib_school !== it.school_name_input) { %>
            <div class="text-xs text-blue-500">→ <%= it.lib_school %></div>
            <% } %>
          </td>
          <td class="px-3 py-2.5 text-gray-700">
            <div><%= it.major_name_input || '—' %></div>
          </td>
          <td class="px-3 py-2.5">
            <div class="flex flex-wrap gap-1">
              <% it.tags.forEach(tag => { %>
              <span class="px-1.5 py-0.5 text-xs rounded border font-medium
                <% if(tag==='unmatched')          { %>bg-red-100 text-red-700 border-red-300
                <% } else if(tag==='selection_mismatch') { %>bg-red-100 text-red-700 border-red-300
                <% } else if(tag==='body_risk')   { %>bg-red-100 text-red-700 border-red-300
                <% } else if(tag==='unmatched_school') { %>bg-red-100 text-red-700 border-red-300
                <% } else if(tag==='major_not_in_plan') { %>bg-orange-100 text-orange-700 border-orange-300
                <% } else if(tag==='no_library')  { %>bg-gray-100 text-gray-500 border-gray-300
                <% } else                         { %>bg-yellow-100 text-yellow-700 border-yellow-300<% } %>">
                <%= tagLabel(tag) %>
              </span>
              <% }) %>
            </div>
          </td>
          <td class="px-3 py-2.5 text-right font-mono text-xs text-gray-500">
            <%= it.rank_ref ? it.rank_ref.toLocaleString() : '—' %>
          </td>
          <td class="px-3 py-2.5 text-right font-mono text-xs">
            <% if(it.rank_ratio !== null) { %>
            <span class="text-red-600 font-semibold"><%= (it.rank_ratio * 100).toFixed(0) %>%</span>
            <% } else { %><span class="text-gray-300">—</span><% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<!-- ═══════════════════════════════════════════════════════════════ -->
<!-- ② 黄色区：建议改 -->
<!-- ═══════════════════════════════════════════════════════════════ -->
<%
const yellowItems = items.filter(it => it.zone === 'yellow');
if (yellowItems.length > 0) { %>
<div class="bg-white rounded-xl shadow border-l-4 border-amber-400 overflow-hidden mb-5">
  <div class="px-5 py-3 bg-amber-50 border-b border-amber-100 flex items-center gap-2">
    <span class="text-lg">🟡</span>
    <h2 class="font-bold text-amber-800">建议改 — 边缘风险</h2>
    <span class="ml-auto text-xs text-amber-400 font-medium"><%= yellowItems.length %> 条</span>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-amber-50/50 text-xs text-amber-600 uppercase tracking-wide">
        <tr>
          <th class="px-3 py-2.5 text-center w-8">序</th>
          <th class="px-3 py-2.5 text-left min-w-[120px]">学校</th>
          <th class="px-3 py-2.5 text-left min-w-[100px]">专业</th>
          <th class="px-3 py-2.5 text-left">风险原因</th>
          <th class="px-3 py-2.5 text-right w-20">参考位次</th>
          <th class="px-3 py-2.5 text-right w-20">位次比</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-amber-50">
        <% yellowItems.forEach(it => { %>
        <tr class="hover:bg-amber-50/30 align-top">
          <td class="px-3 py-2.5 text-center text-gray-400 font-mono"><%= it.seq %></td>
          <td class="px-3 py-2.5">
            <div class="font-medium text-gray-900"><%= it.school_name_input || '—' %></div>
            <% if(it.lib_school && it.lib_school !== it.school_name_input) { %>
            <div class="text-xs text-blue-500">→ <%= it.lib_school %></div>
            <% } %>
          </td>
          <td class="px-3 py-2.5 text-gray-700">
            <div><%= it.major_name_input || '—' %></div>
          </td>
          <td class="px-3 py-2.5">
            <div class="flex flex-wrap gap-1">
              <% it.tags.forEach(tag => { %>
              <span class="px-1.5 py-0.5 text-xs rounded border font-medium
                <% if(tag==='maybe_unwanted_coop') { %>bg-amber-100 text-amber-700 border-amber-300
                <% } else if(tag==='major_not_in_plan') { %>bg-orange-100 text-orange-700 border-orange-300
                <% } else                          { %>bg-yellow-100 text-yellow-700 border-yellow-300<% } %>">
                <%= tagLabel(tag) %>
              </span>
              <% }) %>
            </div>
          </td>
          <td class="px-3 py-2.5 text-right font-mono text-xs text-gray-500">
            <%= it.rank_ref ? it.rank_ref.toLocaleString() : '—' %>
          </td>
          <td class="px-3 py-2.5 text-right font-mono text-xs">
            <% if(it.rank_ratio !== null) { %>
            <span class="text-amber-600 font-semibold"><%= (it.rank_ratio * 100).toFixed(0) %>%</span>
            <% } else { %><span class="text-gray-300">—</span><% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<!-- ═══════════════════════════════════════════════════════════════ -->
<!-- 绿色区 + 未知区 完整列表（折叠式） -->
<!-- ═══════════════════════════════════════════════════════════════ -->
<%
const greenItems = items.filter(it => it.zone === 'green');
const unknownItems = items.filter(it => it.zone === 'unknown');
if (greenItems.length > 0 || unknownItems.length > 0) { %>
<details class="bg-white rounded-xl shadow mb-5" open>
  <summary class="px-5 py-3 cursor-pointer select-none flex items-center gap-2 border-b border-gray-100">
    <span class="text-lg">🟢</span>
    <h2 class="font-semibold text-gray-700">安全 + 无数据</h2>
    <span class="text-xs text-gray-400 ml-2">绿色 <%= greenItems.length %> 条 · 未知 <%= unknownItems.length %> 条 — 点击展开</span>
  </summary>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 text-xs text-gray-500 uppercase tracking-wide">
        <tr>
          <th class="px-3 py-2.5 text-center w-8">序</th>
          <th class="px-3 py-2.5 text-left min-w-[120px]">学校</th>
          <th class="px-3 py-2.5 text-left min-w-[100px]">专业</th>
          <th class="px-3 py-2.5 text-center w-16">区间</th>
          <th class="px-3 py-2.5 text-left">标签</th>
          <th class="px-3 py-2.5 text-right w-20">参考位次</th>
          <th class="px-3 py-2.5 text-right w-20">位次比</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        <% [...greenItems, ...unknownItems].forEach(it => { %>
        <tr class="hover:bg-gray-50 align-top">
          <td class="px-3 py-2.5 text-center text-gray-400 font-mono"><%= it.seq %></td>
          <td class="px-3 py-2.5">
            <div class="font-medium text-gray-900"><%= it.school_name_input || '—' %></div>
            <% if(it.lib_school && it.lib_school !== it.school_name_input) { %>
            <div class="text-xs text-blue-500">→ <%= it.lib_school %></div>
            <% } %>
          </td>
          <td class="px-3 py-2.5 text-gray-700"><%= it.major_name_input || '—' %></td>
          <td class="px-3 py-2.5 text-center">
            <% if(it.zone === 'green') { %>
            <span class="px-2 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-700 border border-green-200">保</span>
            <% } else { %>
            <span class="px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-500 border border-gray-200">?</span>
            <% } %>
          </td>
          <td class="px-3 py-2.5">
            <div class="flex flex-wrap gap-1">
              <% (it.tags || []).forEach(tag => { %>
              <span class="px-1.5 py-0.5 text-xs rounded border bg-gray-50 text-gray-500 border-gray-200"><%= tagLabel(tag) %></span>
              <% }) %>
            </div>
          </td>
          <td class="px-3 py-2.5 text-right font-mono text-xs text-gray-500">
            <%= it.rank_ref ? it.rank_ref.toLocaleString() : '—' %>
          </td>
          <td class="px-3 py-2.5 text-right font-mono text-xs">
            <% if(it.rank_ratio !== null) { %>
            <span class="text-green-600 font-semibold"><%= (it.rank_ratio * 100).toFixed(0) %>%</span>
            <% } else { %><span class="text-gray-300">—</span><% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</details>
<% } %>

<!-- ═══════════════════════════════════════════════════════════════ -->
<!-- ③ SVG 折线图：seq vs rank + 学生位次横线 -->
<!-- ═══════════════════════════════════════════════════════════════ -->
<% if(items.length > 0) { %>
<%
  // 准备图表数据
  const chartItems = items.filter(it => it.rank_ref != null);
  const sRank = student.rank;
  const allRanks = chartItems.map(it => it.rank_ref).concat(sRank ? [sRank] : []).filter(Boolean);
  const maxRank = Math.max(...allRanks);
  const minRank = Math.min(...allRanks);
  // 图表参数
  const W = 680, H = 260;
  const padL = 60, padR = 20, padT = 30, padB = 40;
  const plotW = W - padL - padR;
  const plotH = H - padT - padB;
  const N = items.length;
  // 使用对数刻度更好看
  const logMin = Math.log10(Math.max(1, minRank * 0.8));
  const logMax = Math.log10(maxRank * 1.2);
  const logRange = logMax - logMin || 1;

  function xOf(seq) { return padL + ((seq - 1) / Math.max(1, N - 1)) * plotW; }
  function yOf(rank) {
    const logV = Math.log10(Math.max(1, rank));
    return padT + (1 - (logV - logMin) / logRange) * plotH;
  }
%>
<div class="bg-white rounded-xl shadow p-5 mb-5">
  <h2 class="font-semibold text-gray-800 mb-3 flex items-center gap-2">
    📈 位次趋势图
    <span class="text-xs text-gray-400 font-normal">横轴志愿序号，纵轴院校最低位次（对数刻度），红色虚线为考生位次</span>
  </h2>
  <% if(chartItems.length < 2) { %>
  <p class="text-sm text-gray-400 text-center py-6">数据点不足 2 个，无法绘制趋势图</p>
  <% } else { %>
  <svg viewBox="0 0 <%= W %> <%= H %>" class="w-full max-w-3xl mx-auto" style="max-height:320px">
    <defs>
      <linearGradient id="areaGrad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#3b82f6" stop-opacity="0.15"/>
        <stop offset="100%" stop-color="#3b82f6" stop-opacity="0.01"/>
      </linearGradient>
    </defs>

    <!-- 网格线 -->
    <% [minRank, Math.round((minRank+maxRank)/2), maxRank].forEach(r => { %>
    <line x1="<%= padL %>" y1="<%= yOf(r) %>" x2="<%= W-padR %>" y2="<%= yOf(r) %>"
          stroke="#e5e7eb" stroke-width="0.5"/>
    <text x="<%= padL - 6 %>" y="<%= yOf(r) + 4 %>" text-anchor="end"
          class="text-[10px] fill-gray-400 font-mono"><%= r >= 1000 ? (r/1000).toFixed(1)+'k' : r %></text>
    <% }) %>

    <!-- Y 轴标签 -->
    <text x="<%= padL/2 %>" y="<%= padT - 8 %>" text-anchor="middle"
          class="text-[9px] fill-gray-400">位次↓</text>
    <!-- X 轴标签 -->
    <text x="<%= W - padR %>" y="<%= H - 4 %>" text-anchor="end"
          class="text-[9px] fill-gray-400">序号 →</text>

    <!-- 学生位次横线（红色虚线） -->
    <% if(sRank) { %>
    <line x1="<%= padL %>" y1="<%= yOf(sRank) %>" x2="<%= W-padR %>" y2="<%= yOf(sRank) %>"
          stroke="#ef4444" stroke-width="1.5" stroke-dasharray="6,3"/>
    <text x="<%= W-padR+2 %>" y="<%= yOf(sRank) + 4 %>"
          class="text-[10px] fill-red-500 font-semibold">考生 <%= sRank.toLocaleString() %></text>
    <% } %>

    <!-- 面积填充 -->
    <%
    const areaPoints = chartItems.map(it => `${xOf(it.seq)},${yOf(it.rank_ref)}`).join(' ');
    const lastChart = chartItems[chartItems.length - 1];
    const firstChart = chartItems[0];
    %>
    <polygon points="<%= xOf(firstChart.seq) %>,<%= padT+plotH %> <%= areaPoints %> <%= xOf(lastChart.seq) %>,<%= padT+plotH %>"
             fill="url(#areaGrad)"/>

    <!-- 折线 -->
    <polyline points="<%= areaPoints %>"
              fill="none" stroke="#3b82f6" stroke-width="2" stroke-linejoin="round"/>

    <!-- 数据点 + 颜色 -->
    <% chartItems.forEach(it => {
      const dotColor = it.zone === 'red' ? '#ef4444' : it.zone === 'yellow' ? '#f59e0b' : it.zone === 'green' ? '#22c55e' : '#9ca3af';
    %>
    <circle cx="<%= xOf(it.seq) %>" cy="<%= yOf(it.rank_ref) %>"
            r="4" fill="<%= dotColor %>" stroke="white" stroke-width="1.5"/>
    <% }) %>

    <!-- X 轴序号刻度 -->
    <% items.forEach((it, idx) => { %>
    <% if(N <= 30 || it.seq % Math.ceil(N/20) === 1) { %>
    <text x="<%= xOf(it.seq) %>" y="<%= padT+plotH+16 %>" text-anchor="middle"
          class="text-[9px] fill-gray-400 font-mono"><%= it.seq %></text>
    <% } %>
    <% }) %>

    <!-- 图例 -->
    <circle cx="<%= padL+10 %>" cy="<%= padT+plotH+32 %>" r="3" fill="#ef4444"/>
    <text x="<%= padL+18 %>" y="<%= padT+plotH+35 %>" class="text-[9px] fill-gray-500">红(退档)</text>
    <circle cx="<%= padL+70 %>" cy="<%= padT+plotH+32 %>" r="3" fill="#f59e0b"/>
    <text x="<%= padL+78 %>" y="<%= padT+plotH+35 %>" class="text-[9px] fill-gray-500">黄(边缘)</text>
    <circle cx="<%= padL+130 %>" cy="<%= padT+plotH+32 %>" r="3" fill="#22c55e"/>
    <text x="<%= padL+138 %>" y="<%= padT+plotH+35 %>" class="text-[9px] fill-gray-500">绿(安全)</text>
    <line x1="<%= padL+185 %>" y1="<%= padT+plotH+32 %>" x2="<%= padL+205 %>" y2="<%= padT+plotH+32 %>"
          stroke="#ef4444" stroke-width="1.5" stroke-dasharray="4,2"/>
    <text x="<%= padL+210 %>" y="<%= padT+plotH+35 %>" class="text-[9px] fill-gray-500">考生位次</text>
  </svg>
  <% } %>
</div>
<% } %>

<!-- ═══════════════════════════════════════════════════════════════ -->
<!-- ④ 建议文本 -->
<!-- ═══════════════════════════════════════════════════════════════ -->
<% if(advice && advice.length > 0) { %>
<div class="bg-white rounded-xl shadow p-5 mb-5">
  <h2 class="font-semibold text-gray-800 mb-3 flex items-center gap-2">
    📋 审单建议
  </h2>
  <div class="space-y-2 text-sm leading-6 text-gray-700">
    <% advice.forEach(line => { %>
    <p><%= line %></p>
    <% }) %>
  </div>
</div>
<% } %>

<!-- ═══════════════════════════════════════════════════════════════ -->
<!-- 完整志愿表（可折叠） -->
<!-- ═══════════════════════════════════════════════════════════════ -->
<% if(items.length > 0) { %>
<details class="bg-white rounded-xl shadow mb-5 print:hidden">
  <summary class="px-5 py-3 cursor-pointer select-none flex items-center gap-2 border-b border-gray-100">
    <h2 class="font-semibold text-gray-700">完整志愿明细</h2>
    <span class="text-xs text-gray-400 ml-2"><%= items.length %> 条 — 点击展开</span>
  </summary>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 text-xs text-gray-500 uppercase tracking-wide">
        <tr>
          <th class="px-3 py-2.5 text-center w-8">序</th>
          <th class="px-3 py-2.5 text-left min-w-[120px]">学校</th>
          <th class="px-3 py-2.5 text-left min-w-[100px]">专业</th>
          <th class="px-3 py-2.5 text-center w-10">地区</th>
          <th class="px-3 py-2.5 text-center w-10">性质</th>
          <th class="px-3 py-2.5 text-center w-16">区间</th>
          <th class="px-3 py-2.5 text-left">风险标签</th>
          <th class="px-3 py-2.5 text-left w-20">选科</th>
          <th class="px-3 py-2.5 text-center w-12">学费</th>
          <th class="px-3 py-2.5 text-center w-14">25位次</th>
          <th class="px-3 py-2.5 text-center w-14">24位次</th>
          <th class="px-3 py-2.5 text-center w-14">参考位次</th>
          <th class="px-3 py-2.5 text-right w-16">位次比</th>
          <th class="px-3 py-2.5 text-left">备注</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        <% items.forEach(it => {
          const rowBg = it.zone === 'red' ? 'bg-red-50/40' : it.zone === 'yellow' ? 'bg-amber-50/40' : it.zone === 'green' ? 'bg-green-50/40' : '';
          // 解析年份分（如有）
          let s2025rank = '—', s2024rank = '—';
          if (it.score2025 && it.score2025.rank) s2025rank = it.score2025.rank.toLocaleString();
          else if (it.lib_min_rank_2025) s2025rank = it.lib_min_rank_2025.toLocaleString();
          if (it.score2024 && it.score2024.rank) s2024rank = it.score2024.rank.toLocaleString();
          else if (it.lib_min_rank_2024) s2024rank = it.lib_min_rank_2024.toLocaleString();
        %>
        <tr class="hover:bg-gray-50 align-top <%= rowBg %>">
          <td class="px-3 py-2.5 text-center text-gray-400 font-mono"><%= it.seq %></td>
          <td class="px-3 py-2.5">
            <div class="font-medium text-gray-900"><%= it.school_name_input || '—' %></div>
            <% if(it.school_code) { %>
            <div class="text-[10px] text-gray-400 font-mono"><%= it.school_code %></div>
            <% } %>
            <% if(it.lib_school && it.lib_school !== it.school_name_input) { %>
            <div class="text-xs text-blue-500">→ <%= it.lib_school %></div>
            <% } %>
          </td>
          <td class="px-3 py-2.5 text-gray-700">
            <div><%= it.major_name_input || '—' %></div>
          </td>
          <td class="px-3 py-2.5 text-center text-xs text-gray-500"><%= it.region || '—' %></td>
          <td class="px-3 py-2.5 text-center text-xs">
            <% if(it.nature === '公办') { %><span class="text-blue-600">公办</span>
            <% } else if(it.nature === '民办') { %><span class="text-orange-600">民办</span>
            <% } else { %><span class="text-gray-400"><%= it.nature || '—' %></span><% } %>
          </td>
          <td class="px-3 py-2.5 text-center">
            <% if(it.zone === 'red') { %>
            <span class="px-2 py-0.5 rounded-full text-xs font-semibold bg-red-100 text-red-700">红</span>
            <% } else if(it.zone === 'yellow') { %>
            <span class="px-2 py-0.5 rounded-full text-xs font-semibold bg-amber-100 text-amber-700">黄</span>
            <% } else if(it.zone === 'green') { %>
            <span class="px-2 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-700">绿</span>
            <% } else { %>
            <span class="px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-500">?</span>
            <% } %>
          </td>
          <td class="px-3 py-2.5">
            <div class="flex flex-wrap gap-1">
              <% (it.tags || []).forEach(tag => { %>
              <span class="px-1.5 py-0.5 text-xs rounded border
                <% if(tag==='unmatched'||tag==='selection_mismatch'||tag==='body_risk'||tag==='unmatched_school') { %>bg-red-50 text-red-600 border-red-200
                <% } else if(tag==='maybe_unwanted_coop') { %>bg-amber-50 text-amber-600 border-amber-200
                <% } else if(tag==='major_not_in_plan') { %>bg-orange-50 text-orange-600 border-orange-200
                <% } else if(tag==='no_library') { %>bg-gray-50 text-gray-400 border-gray-200
                <% } else { %>bg-yellow-50 text-yellow-600 border-yellow-200<% } %>">
                <%= tagLabel(tag) %>
              </span>
              <% }) %>
            </div>
          </td>
          <td class="px-3 py-2.5 text-xs text-gray-600"><%= it.selection_req || it.lib_selection_req || '—' %></td>
          <td class="px-3 py-2.5 text-center text-xs <%= it.tuition === '待定' ? 'text-orange-500' : 'text-gray-500' %>"><%= it.tuition || '—' %></td>
          <td class="px-3 py-2.5 text-center font-mono text-xs text-gray-500"><%= s2025rank %></td>
          <td class="px-3 py-2.5 text-center font-mono text-xs text-gray-500"><%= s2024rank %></td>
          <td class="px-3 py-2.5 text-right font-mono text-xs text-gray-500">
            <%= it.rank_ref ? it.rank_ref.toLocaleString() : '—' %>
          </td>
          <td class="px-3 py-2.5 text-right font-mono text-xs">
            <% if(it.rank_ratio !== null) { %>
            <span class="<%= it.rank_ratio >= 1.25 ? 'text-green-600' : it.rank_ratio >= 0.9 ? 'text-amber-600' : 'text-red-600' %> font-semibold">
              <%= (it.rank_ratio * 100).toFixed(0) %>%
            </span>
            <% } else { %><span class="text-gray-300">—</span><% } %>
          </td>
          <td class="px-3 py-2.5 text-xs text-gray-400 max-w-[120px] break-words"><%= it.note || '' %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</details>
<% } %>

<!-- 说明框 -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-5">
  <div class="bg-blue-50 border border-blue-100 rounded-xl p-4 text-xs text-blue-700 leading-5">
    <strong class="block mb-1">📊 位次比说明</strong>
    位次比 = 院校最低位次 ÷ 考生位次。<br>
    <span class="text-green-600 font-medium">≥125%（绿）</span>：保底区间，考生位次显著优于院校线；<br>
    <span class="text-amber-600 font-medium">90%~125%（黄）</span>：边缘区间，冲稳之间；<br>
    <span class="text-red-500 font-medium">＜90%（红）</span>：够不到，录取概率极低。
  </div>
  <div class="bg-amber-50 border border-amber-100 rounded-xl p-4 text-xs text-amber-700 leading-5">
    <strong class="block mb-1">🏷 风险标签说明</strong>
    <span class="font-medium text-red-600">缺少录取数据</span>：院校未找到任何录取位次信息，无法评估风险；<br>
    <span class="font-medium text-red-600">选科不满足</span>：考生选科组合不符合该专业要求，投档即退档；<br>
    <span class="font-medium text-red-600">体检受限</span>：考生身体情况与该专业体检要求冲突；<br>
    <span class="font-medium text-amber-600">中外合作未确认</span>：该专业为中外合作办学，学费较高，请确认是否接受。
  </div>
</div>

<!-- 页脚 -->
<footer class="mt-8 pt-4 border-t border-gray-200 text-center">
  <p class="text-[11px] text-gray-400 leading-5">
    数据来源：手工维护自重庆市考试院/高校招生章程公开材料；版本：2026-05-27；以考试院最终录取为准。
  </p>
</footer>

<%- include('_foot') %>
